rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // News posts: anyone can read, only signed-in admins can write.
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // An admin is an authenticated Google account on the allowlist.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'eliyahu.lev@gmail.com',
          'tuvi2b@gmail.com'
        ];
    }
  }
}
